# 复制本文件为 .env，填入你自己的密钥（.env 不会上传 git）
# 拆条工作只需要 DEEPSEEK_API_KEY 一项，其余可留空

# 【必填】DeepSeek API 密钥：去 https://platform.deepseek.com 注册 → 充值 → 创建 API Key，粘贴到这里
DEEPSEEK_API_KEY=

DEEPSEEK_BASE_URL=https://api.deepseek.com

# 拆条用的快模型（不要用推理模型 deepseek-v4-pro，慢且费 token）
INGEST_MODEL=deepseek-v4-flash

# 以下仅"跑视频分析后端"才需要，纯拆条不用填
TIKHUB_TOKEN=
DEEPSEEK_MODEL=deepseek-v4-pro

# ASR_PROVIDER=local 使用本地 Whisper；ASR_PROVIDER=dashscope 使用阿里云百炼 ASR
# 本地开发默认 local，线上/演示提速时改成 dashscope 并填写 DASHSCOPE_API_KEY
ASR_PROVIDER=local
DASHSCOPE_API_KEY=
# 可选：默认使用录音文件识别批量模型，优先把音频 URL 直传给阿里云
# DASHSCOPE_ASR_MODEL=paraformer-v2
# DASHSCOPE_ASR_WAIT_TIMEOUT=120
